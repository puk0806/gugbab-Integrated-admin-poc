{
  "name": "@gugbab-integrated-admin-poc/gugbab-next-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env-shell APP_ENV=local pnpm start",
    "build": "cross-env-shell APP_ENV=local && env-cmd -f ./env/.env.local next build --debug",
    "postbuild": "sh scripts/postbuild.sh",
    "build:docker": "docker build -t gugbab-next-admin -f Dockerfile ../../",
    "start:dev": "node .next/standalone/apps/gugbab-next-admin/pre-start/index.js next-env -e dev -m production &&  node .next/standalone/apps/gugbab-next-admin/server.js",
    "start:docker": "docker run -d -p 30200:30200 --name gugbab-next-admin gugbab-next-admin",
    "start": "cross-env-shell node scripts/pre-start.js next-env -e ${APP_ENV} -m development && node server.js",
    "lint": "next lint",
    "typecheck": "tsc -b tsconfig.json",
    "test": "jest",
    "generate-schema": "bash scripts/generate/generate-schema.sh"
  },
  "dependencies": {
    "@gugbab-integrated-admin-poc/gugbab-types": "workspace:*",
    "@gugbab-integrated-admin-poc/icons": "workspace:*",
    "@gugbab-integrated-admin-poc/ui-sass": "workspace:*",
    "@gugbab-integrated-admin-poc/utils": "workspace:*",
    "@hookform/resolvers": "^3.3.4",
    "@tanstack/react-query": "^5.59.16",
    "@tanstack/react-query-devtools": "^5.59.16",
    "cookies-next": "^5.0.2",
    "next": "^15.2.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.51.1",
    "yargs": "^17.7.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@gugbab-integrated-admin-poc/eslint-config": "workspace:*",
    "@gugbab-integrated-admin-poc/tsconfig": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@types/testing-library__react": "^10.2.0",
    "@vanilla-extract/next-plugin": "^2.4.6",
    "babel-plugin-react-compiler": "19.0.0-beta-e993439-20250328",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.2.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "sass": "^1.80.6",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "5.3.3"
  }
}
