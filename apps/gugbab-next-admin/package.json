{
  "name": "@gugbab-integrated-admin-poc/gugbab-next-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env-shell APP_ENV=local pnpm start",
    "build": "cross-env-shell APP_ENV=local && env-cmd -f ./env/.env.local next build --debug",
    "build:copy": "sh ./scripts/postbuild.sh",
    "build:dev": "pnpm run build && pnpm run build:copy",
    "build:docker": "docker build -t gugbab-next-admin -f Dockerfile ../../",
    "start:dev": "node .next/standalone/apps/search/server.js",
    "start:docker": "docker run -d -p 30200:30200 --name gugbab-next-admin gugbab-next-admin",
    "start": "cross-env-shell node scripts/pre-start.js next-env -e ${APP_ENV} -m development && node server.js",
    "lint": "next lint",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@gugbab-integrated-admin-poc/ui-sass": "workspace:*",
    "@gugbab-integrated-admin-poc/utils": "workspace:*",
    "@tanstack/react-query": "^5.59.16",
    "@tanstack/react-query-devtools": "^5.59.16",
    "next": "^14.2.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.1",
    "yargs": "^17.7.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@gugbab-integrated-admin-poc/eslint-config": "workspace:*",
    "@gugbab-integrated-admin-poc/tsconfig": "workspace:*",
    "@types/node": "^20",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vanilla-extract/next-plugin": "^2.4.6",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.6",
    "sass": "^1.80.6",
    "typescript": "5.3.3"
  }
}
