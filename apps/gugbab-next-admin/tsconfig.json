{
  "extends": "@gugbab-integrated-admin-poc/tsconfig/nextjs.json",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["node", "jest", "@testing-library/jest-dom"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@app/feature/*": ["src/feature/*"],
      "@app/shared/*": ["src/shared/*"],
      "@app/widgets/*": ["src/widgets/*"]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    // "next.config.js",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"],
  "engines": {
    "node": ">=20",
    "packageManager": "pnpm@9.12.2"
  }
}
