# AG Grid 데이터 그리드 가이드라인

## AG Grid 기본 설정

### 1. 기본 그리드 컴포넌트

```typescript
import { AgGridReact } from 'ag-grid-react';
import { ColDef, GridOptions } from 'ag-grid-community';
import 'ag-grid-community/styles/ag-grid.css';
import 'ag-grid-community/styles/ag-theme-alpine.css';

interface User {
  id: string;
  name: string;
  email: string;
  role: string;
  createdAt: Date;
}

const columnDefs: ColDef<User>[] = [
  {
    field: 'id',
    headerName: 'ID',
    width: 100,
    sortable: true,
    filter: true,
  },
  {
    field: 'name',
    headerName: '이름',
    width: 150,
    sortable: true,
    filter: 'agTextColumnFilter',
  },
  {
    field: 'email',
    headerName: '이메일',
    width: 200,
    sortable: true,
    filter: 'agTextColumnFilter',
  },
  {
    field: 'role',
    headerName: '역할',
    width: 120,
    sortable: true,
    filter: 'agSetColumnFilter',
  },
  {
    field: 'createdAt',
    headerName: '생성일',
    width: 150,
    sortable: true,
    filter: 'agDateColumnFilter',
    valueFormatter: (params) => {
      return new Date(params.value).toLocaleDateString('ko-KR');
    },
  },
];

const gridOptions: GridOptions<User> = {
  columnDefs,
  rowData: [],
  pagination: true,
  paginationPageSize: 20,
  paginationPageSizeSelector: [10, 20, 50, 100],
  defaultColDef: {
    resizable: true,
    sortable: true,
    filter: true,
  },
  animateRows: true,
  rowSelection: 'multiple',
  suppressRowClickSelection: true,
};

function UserGrid({ users }: { users: User[] }) {
  return (
    <div className="ag-theme-alpine" style={{ height: 500, width: '100%' }}>
      <AgGridReact<User>
        columnDefs={columnDefs}
        rowData={users}
        gridOptions={gridOptions}
      />
    </div>
  );
}
```

### 2. 커스텀 셀 렌더러

```typescript
// 커스텀 셀 렌더러 컴포넌트
const StatusCellRenderer = (props: ICellRendererParams) => {
  const status = props.value;
  const statusClass = status === 'active' ? 'status-active' : 'status-inactive';
  
  return (
    <span className={`status-badge ${statusClass}`}>
      {status === 'active' ? '활성' : '비활성'}
    </span>
  );
};

// 액션 버튼 셀 렌더러
const ActionCellRenderer = (props: ICellRendererParams) => {
  const handleEdit = () => {
    // 편집 로직
    console.log('Edit user:', props.data);
  };
  
  const handleDelete = () => {
    // 삭제 로직
    console.log('Delete user:', props.data);
  };
  
  return (
    <div className="action-buttons">
      <button onClick={handleEdit} className="btn-edit">
        편집
      </button>
      <button onClick={handleDelete} className="btn-delete">
        삭제
      </button>
    </div>
  );
};

// 컬럼 정의에 커스텀 렌더러 추가
const columnDefs: ColDef<User>[] = [
  // ... 기존 컬럼들
  {
    field: 'status',
    headerName: '상태',
    width: 100,
    cellRenderer: StatusCellRenderer,
  },
  {
    headerName: '액션',
    width: 150,
    cellRenderer: ActionCellRenderer,
    sortable: false,
    filter: false,
  },
];
```

### 3. 서버 사이드 데이터 처리

```typescript
// 서버 사이드 데이터 소스
const createServerSideDatasource = (apiUrl: string) => {
  return {
    getRows: async (params: IServerSideGetRowsParams) => {
      try {
        const response = await fetch(apiUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            startRow: params.request.startRow,
            endRow: params.request.endRow,
            sortModel: params.request.sortModel,
            filterModel: params.request.filterModel,
          }),
        });
        
        const data = await response.json();
        
        params.success({
          rowData: data.rows,
          rowCount: data.totalRows,
        });
      } catch (error) {
        params.fail();
      }
    },
  };
};

// 그리드 옵션에 서버 사이드 설정 추가
const gridOptions: GridOptions<User> = {
  // ... 기존 옵션들
  rowModelType: 'serverSide',
  serverSideStoreType: 'partial',
  cacheBlockSize: 100,
  maxBlocksInCache: 10,
  onGridReady: (params) => {
    const dataSource = createServerSideDatasource('/api/users');
    params.api.setServerSideDatasource(dataSource);
  },
};
```

### 4. 고급 필터링 및 정렬

```typescript
// 고급 필터링 설정
const advancedColumnDefs: ColDef<User>[] = [
  {
    field: 'name',
    headerName: '이름',
    filter: 'agTextColumnFilter',
    filterParams: {
      filterOptions: ['contains', 'notContains', 'startsWith', 'endsWith'],
      defaultOption: 'contains',
      caseSensitive: false,
    },
  },
  {
    field: 'role',
    headerName: '역할',
    filter: 'agSetColumnFilter',
    filterParams: {
      valueFormatter: (params) => {
        const roleMap = {
          admin: '관리자',
          user: '사용자',
          moderator: '모더레이터',
        };
        return roleMap[params.value] || params.value;
      },
    },
  },
  {
    field: 'createdAt',
    headerName: '생성일',
    filter: 'agDateColumnFilter',
    filterParams: {
      comparator: (filterLocalDateAtMidnight, cellValue) => {
        const dateAsString = cellValue;
        const dateParts = dateAsString.split('/');
        const cellDate = new Date(
          Number(dateParts[2]),
          Number(dateParts[1]) - 1,
          Number(dateParts[0])
        );
        
        if (filterLocalDateAtMidnight.getTime() === cellDate.getTime()) {
          return 0;
        }
        
        if (cellDate < filterLocalDateAtMidnight) {
          return -1;
        }
        
        if (cellDate > filterLocalDateAtMidnight) {
          return 1;
        }
      },
    },
  },
];
```

### 5. 그리드 이벤트 처리

```typescript
// 그리드 이벤트 핸들러
const handleGridReady = (params: GridReadyEvent) => {
  console.log('Grid is ready');
  params.api.sizeColumnsToFit();
};

const handleRowSelected = (event: RowSelectedEvent) => {
  const selectedRows = event.api.getSelectedRows();
  console.log('Selected rows:', selectedRows);
};

const handleCellClicked = (event: CellClickedEvent) => {
  console.log('Cell clicked:', event.data, event.column.getColId());
};

const handleSortChanged = (event: SortChangedEvent) => {
  const sortModel = event.api.getSortModel();
  console.log('Sort changed:', sortModel);
};

const handleFilterChanged = (event: FilterChangedEvent) => {
  const filterModel = event.api.getFilterModel();
  console.log('Filter changed:', filterModel);
};

// 그리드 옵션에 이벤트 핸들러 추가
const gridOptions: GridOptions<User> = {
  // ... 기존 옵션들
  onGridReady: handleGridReady,
  onRowSelected: handleRowSelected,
  onCellClicked: handleCellClicked,
  onSortChanged: handleSortChanged,
  onFilterChanged: handleFilterChanged,
};
```

## 개발 가이드라인

### 1. 성능 최적화
- **가상화**: 대용량 데이터의 경우 서버 사이드 처리 사용
- **컬럼 정의**: 필요한 컬럼만 표시하고 불필요한 컬럼 숨김
- **데이터 캐싱**: 적절한 캐시 설정으로 서버 요청 최소화
- **렌더링 최적화**: 무거운 셀 렌더러는 메모이제이션 사용

### 2. 접근성 고려사항
- **키보드 네비게이션**: 키보드로 그리드 탐색 가능하도록 설정
- **스크린 리더**: ARIA 속성과 적절한 라벨링 제공
- **고대비 모드**: 고대비 테마 지원

### 3. 반응형 디자인
- **컬럼 크기 조정**: 화면 크기에 따른 자동 크기 조정
- **모바일 최적화**: 터치 인터페이스에 적합한 설정
- **테마 적용**: 프로젝트 디자인 시스템과 일치하는 테마 사용

### 4. 데이터 관리
- **상태 관리**: 그리드 상태를 전역 상태와 동기화
- **데이터 검증**: 입력 데이터의 유효성 검사
- **에러 처리**: 데이터 로딩 실패 시 적절한 에러 처리

