# Zustand 상태 관리 가이드라인

## Zustand 기본 사용법

### 1. 기본 스토어 생성

```typescript
import { create } from 'zustand';
import { devtools, persist } from 'zustand/middleware';

interface UserState {
  user: User | null;
  isLoading: boolean;
  error: string | null;
  login: (credentials: LoginCredentials) => Promise<void>;
  logout: () => void;
  setUser: (user: User) => void;
  setLoading: (loading: boolean) => void;
  setError: (error: string | null) => void;
}

interface User {
  id: string;
  name: string;
  email: string;
  role: string;
}

interface LoginCredentials {
  email: string;
  password: string;
}

export const useUserStore = create<UserState>()(
  devtools(
    persist(
      (set, get) => ({
        user: null,
        isLoading: false,
        error: null,
        
        login: async (credentials) => {
          set({ isLoading: true, error: null });
          
          try {
            const response = await fetch('/api/auth/login', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(credentials),
            });
            
            if (!response.ok) {
              throw new Error('로그인에 실패했습니다');
            }
            
            const user = await response.json();
            set({ user, isLoading: false });
          } catch (error) {
            set({ 
              error: error instanceof Error ? error.message : '알 수 없는 오류가 발생했습니다',
              isLoading: false 
            });
          }
        },
        
        logout: () => {
          set({ user: null, error: null });
        },
        
        setUser: (user) => set({ user }),
        setLoading: (isLoading) => set({ isLoading }),
        setError: (error) => set({ error }),
      }),
      {
        name: 'user-storage',
        partialize: (state) => ({ user: state.user }), // user만 저장
      }
    ),
    {
      name: 'user-store',
    }
  )
);
```

### 2. 복잡한 스토어 구조

```typescript
import { create } from 'zustand';
import { immer } from 'zustand/middleware/immer';

interface TodoState {
  todos: Todo[];
  filter: 'all' | 'active' | 'completed';
  addTodo: (text: string) => void;
  toggleTodo: (id: string) => void;
  removeTodo: (id: string) => void;
  setFilter: (filter: 'all' | 'active' | 'completed') => void;
  getFilteredTodos: () => Todo[];
}

interface Todo {
  id: string;
  text: string;
  completed: boolean;
  createdAt: Date;
}

export const useTodoStore = create<TodoState>()(
  immer((set, get) => ({
    todos: [],
    filter: 'all',
    
    addTodo: (text) => set((state) => {
      state.todos.push({
        id: Date.now().toString(),
        text,
        completed: false,
        createdAt: new Date(),
      });
    }),
    
    toggleTodo: (id) => set((state) => {
      const todo = state.todos.find(t => t.id === id);
      if (todo) {
        todo.completed = !todo.completed;
      }
    }),
    
    removeTodo: (id) => set((state) => {
      state.todos = state.todos.filter(t => t.id !== id);
    }),
    
    setFilter: (filter) => set({ filter }),
    
    getFilteredTodos: () => {
      const { todos, filter } = get();
      switch (filter) {
        case 'active':
          return todos.filter(todo => !todo.completed);
        case 'completed':
          return todos.filter(todo => todo.completed);
        default:
          return todos;
      }
    },
  }))
);
```

### 3. 스토어 조합 및 분리

```typescript
// 개별 스토어들
interface AuthState {
  user: User | null;
  isAuthenticated: boolean;
  login: (credentials: LoginCredentials) => Promise<void>;
  logout: () => void;
}

interface UIState {
  theme: 'light' | 'dark';
  sidebarOpen: boolean;
  toggleTheme: () => void;
  toggleSidebar: () => void;
}

// 스토어 조합
export const useAuthStore = create<AuthState>()(
  devtools(
    persist(
      (set) => ({
        user: null,
        isAuthenticated: false,
        login: async (credentials) => {
          // 로그인 로직
          set({ user: { id: '1', name: 'User' }, isAuthenticated: true });
        },
        logout: () => set({ user: null, isAuthenticated: false }),
      }),
      { name: 'auth-storage' }
    ),
    { name: 'auth-store' }
  )
);

export const useUIStore = create<UIState>()(
  devtools(
    persist(
      (set) => ({
        theme: 'light',
        sidebarOpen: false,
        toggleTheme: () => set((state) => ({ 
          theme: state.theme === 'light' ? 'dark' : 'light' 
        })),
        toggleSidebar: () => set((state) => ({ 
          sidebarOpen: !state.sidebarOpen 
        })),
      }),
      { name: 'ui-storage' }
    ),
    { name: 'ui-store' }
  )
);
```

### 4. 비동기 액션과 에러 처리

```typescript
import { create } from 'zustand';

interface AsyncState<T> {
  data: T | null;
  loading: boolean;
  error: string | null;
}

interface UserListState extends AsyncState<User[]> {
  fetchUsers: () => Promise<void>;
  addUser: (user: Omit<User, 'id'>) => Promise<void>;
  updateUser: (id: string, updates: Partial<User>) => Promise<void>;
  deleteUser: (id: string) => Promise<void>;
}

export const useUserListStore = create<UserListState>()(
  devtools(
    (set, get) => ({
      data: null,
      loading: false,
      error: null,
      
      fetchUsers: async () => {
        set({ loading: true, error: null });
        
        try {
          const response = await fetch('/api/users');
          if (!response.ok) throw new Error('사용자 목록을 불러올 수 없습니다');
          
          const users = await response.json();
          set({ data: users, loading: false });
        } catch (error) {
          set({ 
            error: error instanceof Error ? error.message : '알 수 없는 오류',
            loading: false 
          });
        }
      },
      
      addUser: async (userData) => {
        set({ loading: true, error: null });
        
        try {
          const response = await fetch('/api/users', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(userData),
          });
          
          if (!response.ok) throw new Error('사용자 추가에 실패했습니다');
          
          const newUser = await response.json();
          set((state) => ({
            data: state.data ? [...state.data, newUser] : [newUser],
            loading: false,
          }));
        } catch (error) {
          set({ 
            error: error instanceof Error ? error.message : '알 수 없는 오류',
            loading: false 
          });
        }
      },
      
      updateUser: async (id, updates) => {
        set({ loading: true, error: null });
        
        try {
          const response = await fetch(`/api/users/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(updates),
          });
          
          if (!response.ok) throw new Error('사용자 수정에 실패했습니다');
          
          const updatedUser = await response.json();
          set((state) => ({
            data: state.data?.map(user => 
              user.id === id ? updatedUser : user
            ) || null,
            loading: false,
          }));
        } catch (error) {
          set({ 
            error: error instanceof Error ? error.message : '알 수 없는 오류',
            loading: false 
          });
        }
      },
      
      deleteUser: async (id) => {
        set({ loading: true, error: null });
        
        try {
          const response = await fetch(`/api/users/${id}`, {
            method: 'DELETE',
          });
          
          if (!response.ok) throw new Error('사용자 삭제에 실패했습니다');
          
          set((state) => ({
            data: state.data?.filter(user => user.id !== id) || null,
            loading: false,
          }));
        } catch (error) {
          set({ 
            error: error instanceof Error ? error.message : '알 수 없는 오류',
            loading: false 
          });
        }
      },
    }),
    { name: 'user-list-store' }
  )
);
```

### 5. 컴포넌트에서 사용

```typescript
import { useUserStore } from '@/store/userStore';
import { useTodoStore } from '@/store/todoStore';

// 컴포넌트에서 스토어 사용
function UserProfile() {
  const { user, logout, isLoading } = useUserStore();
  const { todos, addTodo, toggleTodo } = useTodoStore();
  
  if (isLoading) return <div>로딩 중...</div>;
  if (!user) return <div>로그인이 필요합니다</div>;
  
  return (
    <div>
      <h1>{user.name}님 환영합니다</h1>
      <button onClick={logout}>로그아웃</button>
      
      <div>
        <h2>할 일 목록</h2>
        {todos.map(todo => (
          <div key={todo.id}>
            <input
              type="checkbox"
              checked={todo.completed}
              onChange={() => toggleTodo(todo.id)}
            />
            <span>{todo.text}</span>
          </div>
        ))}
      </div>
    </div>
  );
}

// 선택적 구독으로 성능 최적화
function TodoCount() {
  const todoCount = useTodoStore((state) => state.todos.length);
  const completedCount = useTodoStore((state) => 
    state.todos.filter(todo => todo.completed).length
  );
  
  return (
    <div>
      <p>전체: {todoCount}개</p>
      <p>완료: {completedCount}개</p>
    </div>
  );
}
```

## 개발 가이드라인

### 1. 스토어 설계 원칙
- **단일 책임**: 각 스토어는 하나의 도메인만 담당
- **불변성**: 상태 변경 시 새로운 객체 생성
- **타입 안전성**: TypeScript를 활용한 완전한 타입 정의
- **선택적 구독**: 필요한 상태만 구독하여 성능 최적화

### 2. 미들웨어 활용
- **devtools**: 개발 도구에서 상태 변화 추적
- **persist**: 브라우저 저장소에 상태 유지
- **immer**: 불변성 관리를 위한 간편한 API
- **subscribeWithSelector**: 선택적 구독을 위한 미들웨어

### 3. 성능 최적화
- **선택적 구독**: 필요한 상태만 구독
- **메모이제이션**: 무거운 계산은 useMemo 활용
- **배치 업데이트**: 여러 상태 변경을 한 번에 처리
- **구조적 공유**: 불필요한 리렌더링 방지

### 4. 테스트 전략
- **단위 테스트**: 각 액션과 리듀서 테스트
- **통합 테스트**: 스토어 간 상호작용 테스트
- **E2E 테스트**: 실제 사용자 시나리오 테스트

