{
  "name": "@gugbab-integrated-admin-poc/ui-sass",
  "version": "0.0.1",
  "description": "gugbab-integrated-admin-poc ui-sass package",
  "author": "gugbab",
  "keywords": [
    "gugbab"
  ],
  "license": "MIT",
  "sideEffects": false,
  "module": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "main": "dist/index.umd.cjs",
  "files": [
    "dist/**",
    "public/styles/abstracts",
    "public/styles/components.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "pnpm build --watch",
    "build": "tsc && tsup",
    "typecheck": "tsc -b tsconfig.json",
    "sass-compile": "sh ./scripts/sass-compile.sh",
    "postbuild": "sh ./scripts/postbuild.sh"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@gugbab-integrated-admin-poc/utils": "workspace:*",
    "@gugbab-integrated-admin-poc/icons": "workspace:*",
    "react-hook-form": "^7.51.1"
  },
  "devDependencies": {
    "@gugbab-integrated-admin-poc/eslint-config": "workspace:*",
    "@gugbab-integrated-admin-poc/tsconfig": "workspace:*",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "sass": "^1.80.6",
    "tsup": "^8.0.2"
  }
}
